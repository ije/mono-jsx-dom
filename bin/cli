#!/usr/bin/env node

import { argv, exit } from "node:process";

switch (argv[2]) {
  case "init":
    import("./init.mjs").then(command => command.run())
    break;
  case "dev":
    import("./dev.mjs").then(command => command.run())
    break;
  case "build": {
    import("./build.mjs").then(command => command.run())
    break;
  }
  default:
    exit(0);
}
