{
  "name": "mono-jsx-dom",
  "version": "0.1.5",
  "description": "A JSX runtime for browsers.",
  "keywords": [
    "jsx",
    "UI",
    "CSR"
  ],
  "type": "module",
  "module": "./index.mjs",
  "types": "./types/index.d.ts",
  "bin": {
    "mono-jsx-dom": "bin/cli"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "node": "./index.mjs",
      "import": "./index.mjs"
    },
    "./jsx-runtime": {
      "types": "./types/jsx-runtime.d.ts",
      "node": "./jsx-runtime.mjs",
      "import": "./jsx-runtime.mjs"
    },
    "./jsx-dev-runtime": {
      "types": "./types/jsx-runtime.d.ts",
      "node": "./jsx-runtime.mjs",
      "import": "./jsx-runtime.mjs"
    },
    "./server": {
      "types": "./types/server.d.ts",
      "workerd": "./server/workerd.mjs",
      "node": "./server/index.mjs",
      "import": "./server/index.mjs"
    },
    "./server/node-fetch-server": {
      "node": "./server/node-fetch-server.mjs",
      "import": "./server/node-fetch-server.mjs"
    }
  },
  "scripts": {
    "prepublishOnly": "deno task build"
  },
  "files": [
    "./*.mjs",
    "./bin/*.mjs",
    "./server/*.mjs",
    "./types/*.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ije/mono-jsx-dom.git"
  },
  "author": "Je Xia <i@jex.me>",
  "license": "MIT"
}
